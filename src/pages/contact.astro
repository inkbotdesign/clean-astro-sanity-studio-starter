---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact — Inkbot Design" description="Contact Inkbot Design.">
  <main class="container mx-auto py-20 px-4 sm:px-6">
    <section class="mx-auto max-w-3xl rounded-2xl border border-zinc-800 bg-zinc-900/70 p-10">
      <h1 class="text-4xl font-bold text-white">Let's create your next brand moment</h1>
      <p class="mt-4 text-lg text-zinc-300">Tell us about your project and we’ll respond within one business day.</p>
      <form class="mt-8 grid gap-4">
        <input type="text" name="name" placeholder="Your name" class="rounded-lg border border-zinc-700 bg-zinc-800 p-3 text-white" />
        <input type="email" name="email" placeholder="Your email" class="rounded-lg border border-zinc-700 bg-zinc-800 p-3 text-white" />
        <input type="text" name="company" placeholder="Company" class="rounded-lg border border-zinc-700 bg-zinc-800 p-3 text-white" />
        <textarea name="message" rows="5" placeholder="Tell us about your project" class="rounded-lg border border-zinc-700 bg-zinc-800 p-3 text-white"></textarea>
        <button type="submit" class="primary-btn">Send Inquiry</button>
      </form>
      <p class="mt-6 text-sm text-zinc-400">Need immediate support? Email <a href="mailto:hello@inkbotdesign.com" class="text-emerald-300">hello@inkbotdesign.com</a></p>
    </section>
  </main>
</BaseLayout>
