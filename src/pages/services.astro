---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "../lib/sanity";

const services = await sanityClient.fetch(`*[_type == "service"] | order(title asc){
  title,
  slug,
  summary,
  subServices[]{ title, description },
}`);
---

<BaseLayout title="Services — Inkbot Design" description="Strategic brand services at Inkbot Design.">
  <main class="container mx-auto py-20 px-4 sm:px-6">
    <header class="mb-12 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-300">Choose your purpose</p>
      <h1 class="mt-4 text-4xl font-bold text-white md:text-6xl">Service suite for ambitious brand teams</h1>
      <p class="mt-4 text-lg text-zinc-300 max-w-3xl mx-auto">Our full-service offering includes brand strategy, experience design, and transformation programs. Every offering is built around your core signature idea.</p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <article key={service.slug.current} class="card p-6">
          <h2 class="text-2xl font-semibold text-white">{service.title}</h2>
          <p class="mt-3 text-zinc-300">{service.summary}</p>
          <a href={`/services/${service.slug.current}`} class="mt-4 inline-block text-emerald-400 font-bold">Explore →</a>
          <ul class="mt-4 space-y-2 text-sm text-zinc-300">
            {service.subServices?.slice(0, 4).map((sub) => (
              <li key={sub.title}>• {sub.title}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
