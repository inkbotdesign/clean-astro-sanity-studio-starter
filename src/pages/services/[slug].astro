---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "../../lib/sanity";

const { slug } = Astro.params;
const service = await sanityClient.fetch(`*[_type == "service" && slug.current == $slug][0]{
  title,
  summary,
  description,
  subServices[]{ title, description, ctaLabel, ctaUrl },
}`, { slug });

if (!service) {
  throw new Error(`Service not found: ${slug}`);
}
---

<BaseLayout title={`${service.title} — Inkbot Design`} description={service.summary}>
  <main class="container mx-auto py-20 px-4 sm:px-6">
    <article class="space-y-8">
      <h1 class="text-5xl font-bold text-white">{service.title}</h1>
      <p class="text-xl text-gray-300">{service.summary}</p>
      <div class="prose max-w-none text-white">
        {service.description?.length ? service.description.map((block) => <p>{block.children[0]?.text}</p>) : <p>{service.summary}</p>}
      </div>

      <section class="mt-10">
        <h2 class="text-3xl font-bold text-white">What this includes</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {service.subServices?.map((sub) => (
            <div key={sub.title} class="border border-zinc-800 p-5 rounded-xl">
              <h3 class="text-xl font-semibold text-white">{sub.title}</h3>
              <p class="mt-2 text-zinc-300">{sub.description}</p>
              {sub.ctaUrl ? <a href={sub.ctaUrl} class="mt-3 inline-block text-emerald-300 font-semibold">{sub.ctaLabel ?? "Learn more"} →</a> : null}
            </div>
          ))}
        </div>
      </section>

      <div class="mt-12">
        <a href="/contact" class="primary-btn">Start this engagement</a>
      </div>
    </article>
  </main>
</BaseLayout>
