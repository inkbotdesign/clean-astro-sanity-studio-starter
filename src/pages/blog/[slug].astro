---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sanityClient } from "../../lib/sanity";

const { slug } = Astro.params;
const post = await sanityClient.fetch(`*[_type == "blogPost" && slug.current == $slug][0]{
  title,
  excerpt,
  publishedAt,
  author,
  body,
}`, { slug });

if (!post) {
  throw new Error(`Blog post not found: ${slug}`);
}
---

<BaseLayout title={`${post.title} — Inkbot Insights`} description={post.excerpt}>
  <main class="container mx-auto py-20 px-4 sm:px-6">
    <article class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold text-white">{post.title}</h1>
      <p class="mt-2 text-sm text-emerald-300">{new Date(post.publishedAt).toLocaleDateString()} • {post.author}</p>
      <div class="mt-8 prose prose-invert text-white">
        {post.body?.map((block) => <p>{block.children[0]?.text}</p>)}
      </div>
      <div class="mt-12">
        <a href="/blog" class="text-emerald-300 font-semibold">← Back to insights</a>
      </div>
    </article>
  </main>
</BaseLayout>
