---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient } from "../lib/sanity";

const posts = await sanityClient.fetch(`*[_type == "blogPost"] | order(publishedAt desc){
  title,
  slug,
  excerpt,
  publishedAt,
  author,
}`);
---

<BaseLayout title="Insights — Inkbot Design" description="Latest brand thinking and analysis.">
  <main class="container mx-auto py-20 px-4 sm:px-6">
    <header class="mb-12 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-300">Insights</p>
      <h1 class="mt-4 text-4xl md:text-6xl font-bold">Latest thinking on brand and experience</h1>
      <p class="mt-4 text-lg text-zinc-300 max-w-3xl mx-auto">Stay ahead with our expert posts on brand strategy, positioning, and transformation.</p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {posts.map((post) => (
        <article key={post.slug.current} class="card p-6">
          <p class="text-xs uppercase text-emerald-300">{new Date(post.publishedAt).toLocaleDateString()}</p>
          <h2 class="mt-2 text-2xl font-bold text-white">{post.title}</h2>
          <p class="mt-3 text-zinc-300">{post.excerpt}</p>
          <a href={`/blog/${post.slug.current}`} class="mt-4 inline-block text-emerald-400 font-semibold">Read full article →</a>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
