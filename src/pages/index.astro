---
import BaseLayout from "../layouts/BaseLayout.astro";
import { sanityClient, urlFor } from "../lib/sanity";

const home = await sanityClient.fetch(`*[_type == "homePage"][0]{
  title,
  tagline,
  heroTitle,
  heroSubtitle,
  heroCtaText,
  heroCtaUrl,
  featuredServices[]-> { title, slug, summary },
  featuredPortfolio[]-> { title, slug, summary, coverImage },
}`);

const services = await sanityClient.fetch(`*[_type == "service"] | order(title asc)[0..8]{ title, slug, summary }`);
const caseStudies = await sanityClient.fetch(`*[_type == "caseStudy"] | order(_createdAt desc)[0..3]{ title, slug, portfolioItem->{title}, keyMetrics, mainImage }`);
const recentPosts = await sanityClient.fetch(`*[_type == "blogPost"] | order(publishedAt desc)[0..3]{ title, slug, excerpt, publishedAt }`);
---

<BaseLayout
  title={home?.title ?? "Inkbot Design | Strategic Branding"}
  description={home?.tagline ?? "Strategic brand systems and experience design for growth-stage teams."}
>
  <main class="container mx-auto pb-20">
    <section class="section grid gap-10 lg:grid-cols-2 items-center">
      <div class="space-y-6">
        <p class="text-sm font-semibold uppercase tracking-wider text-emerald-300">{home?.tagline ?? "Strategic Brand Studio"}</p>
        <h1 class="text-4xl font-bold leading-tight text-white sm:text-6xl">{home?.heroTitle ?? "We build brand-led experiences that scale."}</h1>
        <p class="max-w-2xl text-lg leading-relaxed text-zinc-300">{home?.heroSubtitle ?? "From brand strategy and naming to identity systems and campaigns, we help product teams turn clarity into conversion."}</p>
        <div class="flex flex-wrap gap-4">
          {home?.heroCtaText ? <a href={home.heroCtaUrl ?? "/contact"} class="primary-btn">{home.heroCtaText}</a> : null}
          <a href="/portfolio" class="rounded-full border border-emerald-400 px-6 py-3 font-semibold text-emerald-300 hover:bg-emerald-500/10 transition">View Portfolio</a>
        </div>
      </div>
      <div class="rounded-[2rem] border border-zinc-700 bg-zinc-900/40 p-6 shadow-soft backdrop-blur-xl">
        <h3 class="mb-4 text-xl font-semibold text-white">Who we work with</h3>
        <ul class="space-y-2 text-zinc-300">
          <li>Growth-stage SaaS</li>
          <li>Fintech & FWA</li>
          <li>B2B marketplaces</li>
          <li>Digital product teams</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <div class="mb-8 flex items-end justify-between gap-6">
        <div>
          <h2 class="text-3xl font-bold text-white">Core services</h2>
          <p class="text-zinc-300">Brand and product work that turns strategy into an owned market position.</p>
        </div>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {(services ?? home?.featuredServices ?? []).map((service) => (
          <article key={service.slug.current} class="card p-5">
            <h3 class="text-lg font-semibold text-white">{service.title}</h3>
            <p class="mt-3 text-sm text-zinc-300">{service.summary}</p>
            <a href={`/services/${service.slug.current}`} class="mt-4 inline-flex text-sm font-semibold text-emerald-300 hover:text-emerald-200">Learn more →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="mb-8">
        <h2 class="text-3xl font-bold text-white">Featured case studies</h2>
        <p class="text-zinc-300">Proof points for measurable brand transforms.</p>
      </div>
      <div class="grid gap-4 lg:grid-cols-3">
        {(caseStudies ?? []).map((study) => (
          <article key={study.slug.current} class="card overflow-hidden">
            <img src={study.mainImage ? urlFor(study.mainImage).width(1200).height(640).auto("format").url() : ""} alt={study.title} class="h-40 w-full object-cover" />
            <div class="p-5">
              <p class="text-xs uppercase tracking-wider text-emerald-300">{study.portfolioItem?.title ?? "Case study"}</p>
              <h3 class="mt-2 text-xl font-semibold text-white">{study.title}</h3>
              <p class="mt-2 text-sm text-zinc-300">{study.keyMetrics?.slice(0, 2).join(" • ")}</p>
              <a href={`/case-studies/${study.slug.current}`} class="mt-4 inline-block text-sm font-semibold text-emerald-300 hover:text-emerald-200">Read case study →</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section">
      <div class="mb-8 flex items-end justify-between gap-6">
        <div>
          <h2 class="text-3xl font-bold text-white">Insights</h2>
          <p class="text-zinc-300">Brand thinking, market research, and design systems playbook.</p>
        </div>
      </div>
      <div class="grid gap-4 md:grid-cols-3">
        {recentPosts.map((post) => (
          <article key={post.slug.current} class="card p-5">
            <p class="text-xs uppercase tracking-wide text-emerald-300">{new Date(post.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</p>
            <h3 class="mt-2 text-lg font-semibold text-white">{post.title}</h3>
            <p class="mt-2 text-sm text-zinc-300">{post.excerpt ?? "Deep dives into strategic brand ops and growth design."}</p>
            <a href={`/blog/${post.slug.current}`} class="mt-4 inline-block text-sm font-semibold text-emerald-300 hover:text-emerald-200">Read more →</a>
          </article>
        ))}
      </div>
    </section>

    <section class="section bg-zinc-950/80 rounded-[2rem] border border-zinc-700 p-10 text-center">
      <h2 class="text-3xl font-bold text-white">Ready to future-proof your brand?</h2>
      <p class="mt-3 text-zinc-300">Schedule a strategy session and get a custom brand roadmap in 3 days.</p>
      <a href="/contact" class="primary-btn mt-6 inline-flex">Book a consultation</a>
    </section>
  </main>
</BaseLayout>
