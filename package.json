{
  "name": "clean-astro-sanity-studio-starter",
  "description": "Astro + Sanity starter with an embedded Studio and Vercel-ready server output.",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "clean": "rm -rf .astro dist .vercel/output",
    "verify": "bun run check && bun run lint && bun run prettier:check",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "prettier:check": "prettier . --check",
    "prettier:format": "prettier . --write"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.1",
    "@astrojs/cloudflare": "^13.1.4",
    "@sanity/astro": "^3.3.1",
    "@sanity/client": "^7.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.0.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "sanity": "^5.17.1",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/vite": "^4.2.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
